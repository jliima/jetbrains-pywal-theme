{
  "name": "Pywal",
  "author": "jliima",
  "dark": true,
  "editorScheme": "pywal-color-scheme",

  "ui": {
    "*": {
      "background":                       "background",
      "foreground":                       "foreground",
      "infoForeground":                   "foreground",

      "selectionBackground":              "accentSubtle",
      "selectionForeground":              "foreground",
      "selectionInactiveBackground":      "highlight",
      "selectionBackgroundInactive":      "highlight",

      "lightSelectionBackground":         "accentHover",
      "lightSelectionForeground":         "foreground",
      "lightSelectionInactiveBackground": "highlight",
      "lightSelectionInactiveForeground": "foreground",

      "disabledBackground":               "background",
      "inactiveBackground":               "background",
      "disabledForeground":               "textDisabled",
      "disabledText":                     "textDisabled",
      "inactiveForeground":               "textDisabled",

      "acceleratorForeground":            "foreground",
      "acceleratorSelectionForeground":   "foreground",

      "errorForeground":                  "error",
      "borderColor":                      "border",
      "disabledBorderColor":              "borderSubtle",
      "focusColor":                       "accentHover",
      "focusedBorderColor":               "borderFocus",

      "separatorForeground":              "textDisabled",
      "separatorColor":                   "border",
      "lineSeparatorColor":               "border",

      "modifiedItemForeground":           "accent"
    },

    "ActionButton": {
      "hoverBackground":    "highlight",
      "hoverBorderColor":   "highlight",
      "pressedBackground":  "accentSubtle",
      "pressedBorderColor": "accentSubtle",
      "focusedBorderColor": "borderFocus"
    },

    "Button": {
      "startBackground":   "surface",
      "endBackground":     "surface",
      "startBorderColor":  "border",
      "endBorderColor":    "border",
      "shadowColor":       "backgroundAlt",
      "default": {
        "foreground":          "foreground",
        "startBackground":     "accentSubtle",
        "endBackground":       "accentSubtle",
        "startBorderColor":    "accentHover",
        "endBorderColor":      "accentHover",
        "focusedBorderColor":  "borderFocus",
        "focusColor":          "accentSubtle",
        "shadowColor":         "backgroundAlt"
      }
    },

    "Borders": {
      "color":               "border",
      "ContrastBorderColor": "borderFocus"
    },

    "ComboBox": {
      "nonEditableBackground": "surface",
      "background":            "surface",
      "ArrowButton": {
        "iconColor":             "foreground",
        "disabledIconColor":     "textDisabled",
        "nonEditableBackground": "surface"
      }
    },

    "CompletionPopup": {
      "Advertiser.background":       "overlay",
      "matchForeground":             "accent",
      "selectionInactiveBackground": "highlight",
      "selectionBackground":         "accentSubtle"
    },

    "Component": {
      "errorFocusColor":           "error",
      "inactiveErrorFocusColor":   "color1",
      "warningFocusColor":         "warning",
      "inactiveWarningFocusColor": "overlay",
      "iconColor":                 "textMuted",
      "hoverIconColor":            "textSecondary"
    },

    "Counter": {
      "background": "accentSubtle",
      "foreground": "foreground"
    },

    "DebuggerPopup.borderColor":          "border",
    "DebuggerTabs.selectedBackground":    "highlight",

    "DefaultTabs": {
      "underlineColor":         "accent",
      "inactiveUnderlineColor": "borderSubtle",
      "hoverBackground":        "highlight",
      "borderColor":            "border"
    },

    "DragAndDrop": {
      "areaForeground":  "foreground",
      "areaBackground":  "accentSubtle",
      "areaBorderColor": "border"
    },

    "Editor": {
      "background":         "background",
      "foreground":         "foreground",
      "shortcutForeground": "accent"
    },

    "EditorPane.inactiveBackground": "background",

    "EditorTabs": {
      "selectedForeground":            "foreground",
      "selectedBackground":            "highlightActive",
      "inactiveMaskColor":             "backgroundAlt",
      "underlineColor":                "accent",
      "underlinedTabBackground":       "accentSubtle",
      "inactiveColoredFileBackground": "background",
      "borderColor":                   "border"
    },

    "FileColor": {
      "Gray":   "overlay",
      "Rose":   "error",
      "Green":  "success",
      "Yellow": "warning",
      "Blue":   "accentSubtle",
      "Violet": "accentSubtle",
      "Orange": "warning"
    },

    "InplaceRefactoringPopup.borderColor": "border",

    "Link": {
      "activeForeground":  "accent",
      "hoverForeground":   "accent",
      "pressedForeground": "accentHover",
      "visitedForeground": "accentHover"
    },

    "List": {
      "hoverBackground":         "highlight",
      "hoverInactiveBackground": "highlight"
    },

    "MenuBar.borderColor": "border",
    "NavBar.borderColor":  "border",

    "Notification": {
      "background":      "surface",
      "borderColor":     "border",
      "errorForeground": "foreground",
      "errorBackground": "error",
      "errorBorderColor": "error",
      "MoreButton.innerBorderColor": "border",
      "ToolWindow": {
        "informativeForeground":  "foreground",
        "informativeBackground":  "accentSubtle",
        "informativeBorderColor": "accentSubtle",
        "warningForeground":      "foreground",
        "warningBackground":      "warning",
        "warningBorderColor":     "warning",
        "errorForeground":        "foreground",
        "errorBackground":        "error",
        "errorBorderColor":       "error"
      }
    },

    "NotificationsToolwindow": {
      "newNotification.background":      "surface",
      "newNotification.hoverBackground": "highlight",
      "Notification.hoverBackground":    "highlight"
    },

    "MemoryIndicator": {
      "allocatedBackground": "overlay",
      "usedBackground":      "accentSubtle"
    },

    "ParameterInfo": {
      "background":                 "overlay",
      "foreground":                 "textSecondary",
      "infoForeground":             "textMuted",
      "currentOverloadBackground":  "highlightActive",
      "currentParameterForeground": "foreground"
    },

    "Plugins": {
      "hoverBackground": "highlight",
      "Tab": {
        "selectedForeground": "foreground",
        "selectedBackground": "accentSubtle",
        "hoverBackground":    "highlight"
      },
      "SearchField.borderColor":  "border",
      "SearchField.background":   "surface",
      "SectionHeader.background": "overlay",
      "tagBackground": "overlay",
      "tagForeground": "textSecondary",
      "Button": {
        "installForeground":     "accent",
        "installBorderColor":    "accent",
        "installFillForeground": "foreground",
        "installFillBackground": "accentSubtle",
        "updateForeground":      "foreground",
        "updateBackground":      "accentSubtle",
        "updateBorderColor":     "accentSubtle"
      }
    },

    "Popup": {
      "paintBorder":         true,
      "borderColor":         "border",
      "inactiveBorderColor": "borderSubtle",
      "Toolbar.borderColor": "border",
      "Header.activeBackground":   "surface",
      "Header.inactiveBackground": "overlay",
      "Advertiser": {
        "foreground":   "foreground",
        "borderColor":  "border",
        "borderInsets": "4,8,3,0"
      }
    },

    "PopupMenu": {
      "borderWidth":  1,
      "borderInsets": "4,1,4,1"
    },

    "ProgressBar": {
      "trackColor":              "surface",
      "progressColor":           "accent",
      "indeterminateStartColor": "accent",
      "indeterminateEndColor":   "accentHover",
      "failedColor":             "error",
      "failedEndColor":          "error",
      "passedColor":             "success",
      "passedEndColor":          "success"
    },

    "SearchEverywhere": {
      "Header.background": "surface",
      "Tab": {
        "selectedForeground": "foreground",
        "selectedBackground": "accentSubtle"
      },
      "SearchField": {
        "background":  "overlay",
        "borderColor": "border"
      },
      "Advertiser.foreground": "textMuted"
    },

    "SearchMatch": {
      "startBackground": "warning",
      "endBackground":   "warning"
    },

    "SearchOption.selectedBackground": "accentSubtle",

    "SegmentedButton": {
      "selectedButtonColor":        "highlightActive",
      "focusedSelectedButtonColor": "accentHover",
      "selectedStartBorderColor":   "border",
      "selectedEndBorderColor":     "border"
    },

    "SpeedSearch": {
      "foreground":      "foreground",
      "borderColor":     "border",
      "background":      "surface",
      "errorForeground": "error"
    },

    "StatusBar.borderColor": "border",

    "TabbedPane": {
      "underlineColor":         "accent",
      "disabledUnderlineColor": "textDisabled",
      "contentAreaColor":       "border",
      "hoverColor":             "highlight",
      "focusColor":             "accentSubtle"
    },

    "TableHeader": {
      "cellBorder":           "3,0,3,0",
      "background":           "surface",
      "separatorColor":       "border",
      "bottomSeparatorColor": "borderSubtle"
    },

    "Table": {
      "stripeColor":     "overlay",
      "hoverBackground": "highlight",
      "gridColor":       "border"
    },

    "TextArea": {
      "background":          "surface",
      "selectionBackground": "selection"
    },

    "TextField": {
      "background":          "surface",
      "selectionBackground": "selection"
    },

    "ToggleButton": {
      "onForeground":  "foreground",
      "onBackground":  "accentSubtle",
      "offForeground": "textMuted",
      "offBackground": "overlay",
      "buttonColor":   "highlight",
      "borderColor":   "border"
    },

    "ToolTip": {
      "background":         "overlay",
      "Actions.background": "surface",
      "infoForeground":     "textMuted",
      "shortcutForeground": "textMuted"
    },

    "ToolWindow": {
      "Header": {
        "background":         "surface",
        "inactiveBackground": "background",
        "borderColor":        "border"
      },
      "HeaderTab": {
        "selectedInactiveBackground": "highlight",
        "hoverBackground":            "highlight",
        "hoverInactiveBackground":    "highlight"
      },
      "Button": {
        "hoverBackground":    "highlight",
        "selectedBackground": "highlight",
        "selectedForeground": "foreground"
      }
    },

    "Tree": {
      "rowHeight":              20,
      "hash":                   "border",
      "hoverBackground":        "highlight",
      "hoverInactiveBackground": "highlight"
    },

    "ValidationTooltip": {
      "errorBackground":   "error",
      "errorBorderColor":  "error",
      "warningBackground": "warning",
      "warningBorderColor": "warning"
    },

    "VersionControl": {
      "Log.Commit": {
        "currentBranchBackground":    "background",
        "unmatchedForeground":         "textDisabled",
        "hoveredBackground":           "highlight",
        "selectionInactiveBackground": "accentSubtle",
        "selectionInactiveForeground": "foreground"
      },
      "FileHistory.Commit.selectedBranchBackground": "accentSubtle"
    },

    "WelcomeScreen.": {
      "Projects.selectionInactiveBackground": "accentSubtle",
      "separatorColor":                        "border",
      "Details.background":                    "surface",
      "Projects.actions.background":           "highlightActive"
    }
  },

  "icons": {
    "ColorPalette": {
      "Actions.Grey":            "textMuted",
      "Actions.Red":             "error",
      "Actions.Yellow":          "warning",
      "Actions.Green":           "success",
      "Actions.Blue":            "accent",
      "Actions.GreyInline.Dark": "textDisabled",
      "Objects.Grey":            "textMuted",
      "Objects.RedStatus":       "error",
      "Objects.Red":             "error",
      "Objects.Pink":            "info",
      "Objects.Yellow":          "warning",
      "Objects.Green":           "success",
      "Objects.Blue":            "accent",
      "Objects.Purple":          "accent",
      "Objects.BlackText":       "textInverse",
      "Objects.YellowDark":      "warning",
      "Objects.GreenAndroid":    "success",
      "Checkbox.Background.Default.Dark":     "highlightActive",
      "Checkbox.Border.Default.Dark":         "border",
      "Checkbox.Foreground.Selected.Dark":    "textSecondary",
      "Checkbox.Focus.Wide.Dark":             "accentHover",
      "Checkbox.Focus.Thin.Default.Dark":     "accentHover",
      "Checkbox.Focus.Thin.Selected.Dark":    "accentHover",
      "Checkbox.Background.Disabled.Dark":    "surface",
      "Checkbox.Border.Disabled.Dark":        "borderSubtle",
      "Checkbox.Foreground.Disabled.Dark":    "textDisabled"
    }
  }
}
